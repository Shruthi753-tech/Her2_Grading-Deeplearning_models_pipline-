{
  "name": "her2-pipeline",
  "displayName": "HER2 Clinical ML Pipeline",
  "description": "Production-ready VS Code extension for HER2 histopathology grading with fully-supervised and weakly-supervised (MIL) workflows",
  "version": "1.0.0",
  "publisher": "clinical-ai",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Data Science",
    "Other"
  ],
  "keywords": [
    "pathology",
    "her2",
    "mil",
    "clinical",
    "histopathology",
    "breast cancer",
    "multiple instance learning"
  ],
  "activationEvents": [
    "onCommand:her2-pipeline.preprocessing",
    "onCommand:her2-pipeline.trainSegmentation",
    "onCommand:her2-pipeline.trainMIL",
    "onCommand:her2-pipeline.previewBags",
    "onCommand:her2-pipeline.viewDashboard",
    "onCommand:her2-pipeline.generateReport",
    "onCommand:her2-pipeline.datasetStats",
    "onCommand:her2-pipeline.tumourFilter",
    "onCommand:her2-pipeline.validateReport"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "her2-pipeline.preprocessing",
        "title": "🩺 HER2: Run Preprocessing Pipeline",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.trainSegmentation",
        "title": "🤖 HER2: Train Segmentation Model",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.trainMIL",
        "title": "🧠 HER2: Train MIL Model",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.previewBags",
        "title": "🎞 HER2: Preview MIL Bags",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.viewDashboard",
        "title": "📊 HER2: View Training Dashboard",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.generateReport",
        "title": "📈 HER2: Generate Clinical Report",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.datasetStats",
        "title": "🩺 Dataset Stats (Legacy)",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.tumourFilter",
        "title": "🔍 Tumour Filter Preview (Legacy)",
        "category": "HER2 Pipeline"
      },
      {
        "command": "her2-pipeline.validateReport",
        "title": "📊 Validate & Report (Legacy)",
        "category": "HER2 Pipeline"
      }
    ],
    "configuration": {
      "title": "HER2 Clinical Pipeline",
      "properties": {
        "her2-pipeline.preprocessing.tileSize": {
          "type": "number",
          "default": 224,
          "description": "Tile size for preprocessing (224px for MIL, 256px for segmentation)",
          "enum": [224, 256, 512]
        },
        "her2-pipeline.preprocessing.overlap": {
          "type": "number",
          "default": 0,
          "description": "Tile overlap in pixels"
        },
        "her2-pipeline.preprocessing.magnification": {
          "type": "number",
          "default": 0.5,
          "description": "Magnification level (mpp resolution)"
        },
        "her2-pipeline.mil.model": {
          "type": "string",
          "default": "clam",
          "description": "MIL model architecture",
          "enum": ["clam", "ab_mil", "transmil"]
        },
        "her2-pipeline.mil.backbone": {
          "type": "string",
          "default": "resnet50",
          "description": "Feature extraction backbone",
          "enum": ["resnet50", "convnext_tiny"]
        },
        "her2-pipeline.mil.maxBagSize": {
          "type": "number",
          "default": 1000,
          "description": "Maximum instances per WSI bag"
        },
        "her2-pipeline.mil.cvFolds": {
          "type": "number",
          "default": 5,
          "description": "Cross-validation folds for patient-level CV"
        },
        "her2-pipeline.clinical.her2Mapping": {
          "type": "object",
          "default": {
            "0": "Negative",
            "1+": "Low",
            "2+": "Low",
            "3+": "High"
          },
          "description": "HER2 score to clinical category mapping (ASCO 2018)"
        },
        "her2-pipeline.dataPath": {
          "type": "string",
          "default": "./slides",
          "description": "Path to input WSI slides directory"
        },
        "her2-pipeline.outputPath": {
          "type": "string",
          "default": "./output",
          "description": "Path to pipeline output directory"
        },
        "her2-pipeline.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Custom Python interpreter path (leave empty for auto-detection)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "child_process": "^1.0.2"
  }
}